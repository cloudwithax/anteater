#!/bin/bash
# Anteater - Main CLI entrypoint.
# Routes subcommands and interactive menu.
# Handles update/remove flows.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/core/common.sh"
source "$SCRIPT_DIR/lib/core/commands.sh"

trap cleanup_temp_files EXIT INT TERM

VERSION="1.0.0"
ANTEATER_TAGLINE="Deep clean your *nix system, based on Mole from tw93"

get_latest_version() {
    curl -fsSL --connect-timeout 2 --max-time 3 -H "Cache-Control: no-cache" \
        "https://raw.githubusercontent.com/cloudwithax/anteater/main/anteater" 2> /dev/null |
        grep '^VERSION=' | head -1 | sed 's/VERSION="\(.*\)"/\1/'
}

get_latest_version_from_github() {
    local version
    version=$(curl -fsSL --connect-timeout 2 --max-time 3 \
        "https://api.github.com/repos/cloudwithax/anteater/releases/latest" 2> /dev/null |
        grep '"tag_name"' | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
    version="${version#v}"
    version="${version#V}"
    echo "$version"
}

get_install_channel() {
    local channel_file="${ANTEATER_CONFIG_DIR:-$HOME/.config/anteater}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    local channel="stable"
    if [[ -f "$channel_file" ]]; then
        channel=$(sed -n 's/^CHANNEL=\(.*\)$/\1/p' "$channel_file" | head -1)
    fi
    case "$channel" in
        nightly | dev | stable) printf '%s\n' "$channel" ;;
        *) printf 'stable\n' ;;
    esac
}

get_install_commit() {
    local channel_file="${ANTEATER_CONFIG_DIR:-$HOME/.config/anteater}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    if [[ -f "$channel_file" ]]; then
        sed -n 's/^COMMIT_HASH=\(.*\)$/\1/p' "$channel_file" | head -1
    fi
}

get_latest_commit_from_github() {
    local sha
    sha=$(curl -fsSL --connect-timeout 2 --max-time 3 \
        "https://api.github.com/repos/cloudwithax/anteater/commits/main" 2> /dev/null |
        grep '"sha"[[:space:]]*:[[:space:]]*"[0-9a-f]\{40\}"' | head -1 | sed -E 's/.*"sha"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
    echo "$sha"
}

# Background update notice
check_for_updates() {
    local msg_cache="$HOME/.cache/anteater/update_message"
    ensure_user_dir "$(dirname "$msg_cache")"
    ensure_user_file "$msg_cache"

    (
        (
            local channel
            channel=$(get_install_channel)

            if [[ "$channel" == "nightly" ]]; then
                local installed_commit latest_commit
                installed_commit=$(get_install_commit)
                latest_commit=$(get_latest_commit_from_github)

                if [[ -n "$installed_commit" && -n "$latest_commit" && "${installed_commit:0:7}" != "${latest_commit:0:7}" ]]; then
                    printf "\nNew nightly commit %s available, run %saa update --nightly%s\n\n" "${latest_commit:0:7}" "$GREEN" "$NC" > "$msg_cache"
                else
                    echo -n > "$msg_cache"
                fi
            else
                local latest

                latest=$(get_latest_version_from_github)
                if [[ -z "$latest" ]]; then
                    latest=$(get_latest_version)
                fi

                if [[ -n "$latest" && "$VERSION" != "$latest" && "$(printf '%s\n' "$VERSION" "$latest" | sort -V | head -1)" == "$VERSION" ]]; then
                    printf "\nUpdate %s available, run %saa update%s\n\n" "$latest" "$GREEN" "$NC" > "$msg_cache"
                else
                    echo -n > "$msg_cache"
                fi
            fi
        ) > /dev/null 2>&1 < /dev/null &
    )
}

show_update_notification() {
    local msg_cache="$HOME/.cache/anteater/update_message"
    if [[ -f "$msg_cache" && -s "$msg_cache" ]]; then
        cat "$msg_cache"
        echo
    fi
}

show_brand_banner() {
    cat << EOF
${GREEN}    _          _                 _            ${NC}
${GREEN}   / \   _ __ | |_ ___  __ _  __| |_ ___ _ __ ${NC}
${GREEN}  / _ \ | '_ \| __/ _ \/ _\` |/ _\` | __/ _ \ '__|${NC}  ${BLUE}https://github.com/cloudwithax/anteater${NC}
${GREEN} / ___ \| | | | ||  __/ (_| | (_| | ||  __/ |   ${NC}  ${GREEN}${ANTEATER_TAGLINE}${NC}
${GREEN}/_/   \_\_| |_|\__\___|\__,_|\__,_|\__\___|_|   ${NC}

EOF
}

show_version() {
    local os_name="Unknown"
    if [[ -r /etc/os-release ]]; then
        os_name=$(. /etc/os-release && printf '%s' "${PRETTY_NAME:-${NAME:-Linux}}")
    elif command -v uname > /dev/null 2>&1; then
        os_name=$(uname -s)
    fi

    local arch
    arch=$(uname -m)

    local kernel
    kernel=$(uname -r)

    local disk_free
    disk_free=$(df -h / 2> /dev/null | awk 'NR==2 {print $4}' || echo "Unknown")

    local channel
    channel=$(get_install_channel)

    printf '\nAnteater version %s\n' "$VERSION"
    if [[ "$channel" == "nightly" ]]; then
        local commit
        commit=$(get_install_commit)
        if [[ -n "$commit" ]]; then
            printf 'Channel: Nightly (%s)\n' "$commit"
        else
            printf 'Channel: Nightly\n'
        fi
    fi
    printf 'OS: %s\n' "$os_name"
    printf 'Architecture: %s\n' "$arch"
    printf 'Kernel: %s\n' "$kernel"
    printf 'Disk Free: %s\n' "$disk_free"
    printf 'Shell: %s\n\n' "${SHELL:-Unknown}"
}

show_help() {
    show_brand_banner
    echo
    printf "%s%s%s\n" "$BLUE" "COMMANDS" "$NC"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa" "$NC" "Main menu"
    for entry in "${ANTEATER_COMMANDS[@]}"; do
        local name="${entry%%:*}"
        local desc="${entry#*:}"
        local display="aa $name"
        [[ "$name" == "help" ]] && display="aa --help"
        [[ "$name" == "version" ]] && display="aa --version"
        printf "  %s%-28s%s %s\n" "$GREEN" "$display" "$NC" "$desc"
    done
    echo
    printf "  %s%-28s%s %s\n" "$GREEN" "aa clean --dry-run" "$NC" "Preview cache cleanup"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa clean --include-cache" "$NC" "Also offer ~/.cache catch-all"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa analyze [path]" "$NC" "Browse disk usage at path (default ~)"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa status" "$NC" "Snapshot of system health"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa optimize --dry-run" "$NC" "Preview maintenance tasks"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa purge --dry-run" "$NC" "Preview project purge"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa purge --paths" "$NC" "Configure scan directories"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa completion --dry-run" "$NC" "Preview shell completion edits"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa update --force" "$NC" "Force reinstall latest stable version"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa update --nightly" "$NC" "Install latest unreleased main branch build"
    printf "  %s%-28s%s %s\n" "$GREEN" "aa remove --dry-run" "$NC" "Preview Anteater removal"
    echo
    printf "%s%s%s\n" "$BLUE" "OPTIONS" "$NC"
    printf "  %s%-28s%s %s\n" "$GREEN" "--debug" "$NC" "Show detailed operation logs"
    echo
}

# Update flow.
update_anteater() {
    local force_update="${1:-false}"
    local nightly_update="${2:-false}"
    local sudo_keepalive_pid=""

    _update_cleanup() {
        [[ -n "$sudo_keepalive_pid" ]] && _stop_sudo_keepalive "$sudo_keepalive_pid" || true
    }
    trap '_update_cleanup; echo ""; exit 130' INT TERM

    local latest=""
    local download_label="Downloading latest version..."
    local install_label="Installing update..."
    local final_success_label="latest version"

    if [[ "$nightly_update" == "true" ]]; then
        latest="main"
        download_label="Downloading nightly installer..."
        install_label="Installing nightly update..."
        final_success_label="nightly build (main)"
    else
        latest=$(get_latest_version_from_github)
        [[ -z "$latest" ]] && latest=$(get_latest_version)

        if [[ -z "$latest" ]]; then
            log_error "Unable to check for updates. Check network connection."
            echo -e "${ICON_REVIEW} Check if you can access GitHub, https://github.com"
            echo -e "${ICON_REVIEW} Try again with: ${GRAY}aa update${NC}"
            exit 1
        fi

        if [[ "$VERSION" == "$latest" && "$force_update" != "true" ]]; then
            echo ""
            echo -e "${GREEN}${ICON_SUCCESS}${NC} Already on latest version, ${VERSION}"
            echo ""
            exit 0
        fi
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "$download_label"
    else
        echo "${download_label%...}"
    fi

    local installer_url="https://raw.githubusercontent.com/cloudwithax/anteater/main/install.sh"
    local tmp_installer
    tmp_installer="$(mktemp_file)" || {
        log_error "Update failed"
        exit 1
    }

    if command -v curl > /dev/null 2>&1; then
        curl -fsSL --connect-timeout 10 --max-time 60 "$installer_url" -o "$tmp_installer" || {
            local curl_exit=$?
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            log_error "Update failed, curl error: $curl_exit"
            echo -e "${ICON_REVIEW} Check network connection and try again."
            echo -e "${ICON_REVIEW} URL: $installer_url"
            exit 1
        }
    elif command -v wget > /dev/null 2>&1; then
        wget --timeout=10 --tries=3 -qO "$tmp_installer" "$installer_url" || {
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            log_error "Update failed, wget error"
            echo -e "${ICON_REVIEW} Check network connection and try again."
            echo -e "${ICON_REVIEW} URL: $installer_url"
            exit 1
        }
    else
        if [[ -t 1 ]]; then stop_inline_spinner; fi
        rm -f "$tmp_installer"
        log_error "curl or wget required"
        exit 1
    fi

    if [[ -t 1 ]]; then stop_inline_spinner; fi
    chmod +x "$tmp_installer"

    local anteater_path
    anteater_path="$(command -v anteater 2> /dev/null || echo "$0")"
    local install_dir
    install_dir="$(cd "$(dirname "$anteater_path")" && pwd)"

    local requires_sudo="false"
    if [[ ! -w "$install_dir" ]]; then
        requires_sudo="true"
    elif [[ -e "$install_dir/anteater" && ! -w "$install_dir/anteater" ]]; then
        requires_sudo="true"
    fi

    if [[ "$requires_sudo" == "true" ]]; then
        if ! request_sudo_access "Anteater update requires admin access"; then
            log_error "Update aborted, admin access denied"
            rm -f "$tmp_installer"
            exit 1
        fi
        sudo_keepalive_pid=$(_start_sudo_keepalive)
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "$install_label"
    else
        echo "${install_label%...}"
    fi

    process_install_output() {
        local output="$1"
        local fallback_version="$2"
        local success_label="$3"
        if [[ -t 1 ]]; then stop_inline_spinner; fi

        local filtered_output
        filtered_output=$(printf '%s\n' "$output" | sed '/^$/d')
        if [[ -n "$filtered_output" ]]; then
            printf '\n%s\n' "$filtered_output"
        fi

        if ! printf '%s\n' "$output" | grep -Eq "Updated to latest version|Already on latest version"; then
            local new_version
            new_version=$("$anteater_path" --version 2> /dev/null | awk '/Anteater version/ {print $3; exit}' || echo "")
            [[ -z "$new_version" ]] && new_version="$fallback_version"
            printf '\n%s\n\n' "${GREEN}${ICON_SUCCESS}${NC} Updated to ${success_label}, ${new_version:-unknown}"
        else
            printf '\n'
        fi
    }

    local install_output
    local update_tag="V${latest#V}"
    local config_dir="${ANTEATER_CONFIG_DIR:-$SCRIPT_DIR}"
    if [[ ! -f "$config_dir/lib/core/common.sh" ]]; then
        config_dir="$HOME/.config/anteater"
    fi

    local installer_version
    if [[ "$nightly_update" == "true" ]]; then
        installer_version="main"
    else
        installer_version="$update_tag"
    fi

    if install_output=$(ANTEATER_VERSION="$installer_version" "$tmp_installer" --prefix "$install_dir" --config "$config_dir" 2>&1); then
        process_install_output "$install_output" "$latest" "$final_success_label"
    else
        if [[ -t 1 ]]; then stop_inline_spinner; fi
        rm -f "$tmp_installer"
        _update_cleanup
        log_error "Update failed"
        echo "$install_output" | tail -10 >&2
        exit 1
    fi

    rm -f "$tmp_installer"
    rm -f "$HOME/.cache/anteater/update_message"

    _update_cleanup
    trap - INT TERM
}

# Remove flow.
remove_anteater() {
    local dry_run_mode="${1:-false}"
    local test_mode=false
    if [[ "${ANTEATER_TEST_MODE:-0}" == "1" ]]; then
        test_mode=true
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "Detecting Anteater installations..."
    else
        echo "Detecting installations..."
    fi

    local -a manual_installs=()
    local -a alias_installs=()

    local found_anteater=""
    if [[ "$test_mode" != "true" ]]; then
        found_anteater=$(command -v anteater 2> /dev/null || true)
        if [[ -n "$found_anteater" && -f "$found_anteater" ]]; then
            manual_installs+=("$found_anteater")
        fi
    fi

    local -a fallback_paths=()
    if [[ "$test_mode" == "true" ]]; then
        fallback_paths=("$HOME/.local/bin/anteater")
    else
        fallback_paths=(
            "/usr/local/bin/anteater"
            "$HOME/.local/bin/anteater"
        )
    fi

    for path in "${fallback_paths[@]}"; do
        if [[ -f "$path" && "$path" != "$found_anteater" ]]; then
            manual_installs+=("$path")
        fi
    done

    local found_aa=""
    if [[ "$test_mode" != "true" ]]; then
        found_aa=$(command -v aa 2> /dev/null || true)
        if [[ -n "$found_aa" && -f "$found_aa" ]]; then
            alias_installs+=("$found_aa")
        fi
    fi

    local -a alias_fallback=()
    if [[ "$test_mode" == "true" ]]; then
        alias_fallback=("$HOME/.local/bin/aa")
    else
        alias_fallback=(
            "/usr/local/bin/aa"
            "$HOME/.local/bin/aa"
        )
    fi

    for alias in "${alias_fallback[@]}"; do
        if [[ -f "$alias" && "$alias" != "$found_aa" ]]; then
            alias_installs+=("$alias")
        fi
    done

    if [[ -t 1 ]]; then
        stop_inline_spinner
    fi

    printf '\n'

    local manual_count=${#manual_installs[@]}
    local alias_count=${#alias_installs[@]}
    if [[ ${manual_count:-0} -eq 0 && ${alias_count:-0} -eq 0 ]]; then
        printf '%s\n\n' "${YELLOW}No Anteater installation detected${NC}"
        exit 0
    fi

    local log_dir="${ANTEATER_LOG_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/anteater/logs}"
    local config_dir="${ANTEATER_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/anteater}"
    local cache_dir="${ANTEATER_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/anteater}"

    if [[ "$dry_run_mode" == "true" ]]; then
        echo -e "${YELLOW}${ICON_DRY_RUN} DRY RUN MODE${NC}, no files will be removed"
        echo ""
        echo -e "${YELLOW}Remove Anteater${NC}, would delete the following:"
        if [[ ${manual_count:-0} -gt 0 ]]; then
            for install in "${manual_installs[@]}"; do
                [[ -f "$install" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: ${install}${NC}"
            done
        fi
        if [[ ${alias_count:-0} -gt 0 ]]; then
            for alias in "${alias_installs[@]}"; do
                [[ -f "$alias" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: ${alias}${NC}"
            done
        fi
        [[ -d "$cache_dir" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: $cache_dir${NC}"
        [[ -d "$config_dir" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: $config_dir${NC}"
        [[ -d "$log_dir" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: $log_dir${NC}"

        printf '\n%s\n\n' "${GREEN}${ICON_SUCCESS}${NC} Dry run complete, no changes made"
        exit 0
    fi

    echo -e "${YELLOW}Remove Anteater${NC}, will delete the following:"
    for install in ${manual_installs[@]+"${manual_installs[@]}"} ${alias_installs[@]+"${alias_installs[@]}"}; do
        echo "  ${ICON_LIST} $install"
    done
    echo "  ${ICON_LIST} $config_dir"
    echo "  ${ICON_LIST} $cache_dir"
    echo "  ${ICON_LIST} $log_dir"
    echo -ne "${PURPLE}${ICON_ARROW}${NC} Press ${GREEN}Enter${NC} to confirm, ${GRAY}ESC${NC} to cancel: "

    IFS= read -r -s -n1 key || key=""
    drain_pending_input
    case "$key" in
        $'\e')
            exit 0
            ;;
        "" | $'\n' | $'\r')
            printf "\r\033[K"
            ;;
        *)
            exit 0
            ;;
    esac

    local has_error=false
    if [[ ${manual_count:-0} -gt 0 ]]; then
        for install in "${manual_installs[@]}"; do
            if [[ -f "$install" ]]; then
                if [[ ! -w "$(dirname "$install")" ]]; then
                    sudo rm -f "$install" 2> /dev/null || has_error=true
                else
                    rm -f "$install" 2> /dev/null || has_error=true
                fi
            fi
        done
    fi
    if [[ ${alias_count:-0} -gt 0 ]]; then
        for alias in "${alias_installs[@]}"; do
            if [[ -f "$alias" ]]; then
                if [[ ! -w "$(dirname "$alias")" ]]; then
                    sudo rm -f "$alias" 2> /dev/null || has_error=true
                else
                    rm -f "$alias" 2> /dev/null || has_error=true
                fi
            fi
        done
    fi
    [[ -d "$cache_dir" ]] && rm -rf "$cache_dir" 2> /dev/null || true
    [[ -d "$config_dir" ]] && rm -rf "$config_dir" 2> /dev/null || true
    [[ -d "$log_dir" ]] && rm -rf "$log_dir" 2> /dev/null || true

    local final_message
    if [[ "$has_error" == "true" ]]; then
        final_message="${YELLOW}${ICON_ERROR} Anteater uninstalled with some errors, thank you for using Anteater!${NC}"
    else
        final_message="${GREEN}${ICON_SUCCESS} Anteater uninstalled successfully, thank you for using Anteater!${NC}"
    fi
    printf '\n%s\n\n' "$final_message"

    exit 0
}

show_main_menu() {
    local selected="${1:-1}"
    local _full_draw="${2:-true}"
    local banner="${MAIN_MENU_BANNER:-}"
    local update_message="${MAIN_MENU_UPDATE_MESSAGE:-}"

    if [[ -z "$banner" ]]; then
        banner="$(show_brand_banner)"
        MAIN_MENU_BANNER="$banner"
    fi

    printf '\033[H'

    local line=""
    printf '\r\033[2K\n'

    while IFS= read -r line || [[ -n "$line" ]]; do
        printf '\r\033[2K%s\n' "$line"
    done <<< "$banner"

    if [[ -n "$update_message" ]]; then
        while IFS= read -r line || [[ -n "$line" ]]; do
            printf '\r\033[2K%s\n' "$line"
        done <<< "$update_message"
    fi

    printf '\r\033[2K\n'

    printf '\r\033[2K%s\n' "$(show_menu_option 1 "Clean        Free up disk space from user caches" "$([[ $selected -eq 1 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 2 "Purge        Remove old project artifacts" "$([[ $selected -eq 2 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 3 "Analyze      Browse disk usage by directory" "$([[ $selected -eq 3 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 4 "Status       Snapshot of system health" "$([[ $selected -eq 4 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 5 "Optimize     Run system maintenance tasks" "$([[ $selected -eq 5 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 6 "Completion   Setup shell tab completion" "$([[ $selected -eq 6 ]] && echo true || echo false)")"

    if [[ -t 0 ]]; then
        printf '\r\033[2K\n'
        local controls="${GRAY}↑↓  |  Enter  |  M More  |  V Version"
        if [[ "${MAIN_MENU_SHOW_UPDATE:-false}" == "true" ]]; then
            controls="${controls}  |  U Update"
        fi
        controls="${controls}  |  Q Quit${NC}"
        printf '\r\033[2K%s\n' "$controls"
        printf '\r\033[2K\n'
    fi

    printf '\033[J'
}

interactive_main_menu() {
    local current_option=1
    local first_draw=true
    local brand_banner=""
    local msg_cache="$HOME/.cache/anteater/update_message"
    local update_message=""

    brand_banner="$(show_brand_banner)"
    MAIN_MENU_BANNER="$brand_banner"

    if [[ -f "$msg_cache" && -s "$msg_cache" ]]; then
        update_message="$(cat "$msg_cache" 2> /dev/null || echo "")"
    fi
    MAIN_MENU_UPDATE_MESSAGE="$update_message"
    MAIN_MENU_SHOW_UPDATE="$([[ -n "$update_message" ]] && echo true || echo false)"

    cleanup_and_exit() {
        show_cursor
        exit 0
    }

    trap cleanup_and_exit INT
    hide_cursor

    while true; do
        show_main_menu $current_option "$first_draw"
        if [[ "$first_draw" == "true" ]]; then
            first_draw=false
        fi

        local key
        if ! key=$(read_key); then
            continue
        fi

        case "$key" in
            "UP") ((current_option > 1)) && ((current_option--)) ;;
            "DOWN") ((current_option < 6)) && ((current_option++)) ;;
            "ENTER")
                show_cursor
                case $current_option in
                    1) exec "$SCRIPT_DIR/bin/clean.sh" ;;
                    2) exec "$SCRIPT_DIR/bin/purge.sh" ;;
                    3) exec "$SCRIPT_DIR/bin/analyze.sh" ;;
                    4) exec "$SCRIPT_DIR/bin/status.sh" ;;
                    5) exec "$SCRIPT_DIR/bin/optimize.sh" ;;
                    6) exec "$SCRIPT_DIR/bin/completion.sh" ;;
                esac
                ;;
            "CHAR:1")
                show_cursor
                exec "$SCRIPT_DIR/bin/clean.sh"
                ;;
            "CHAR:2")
                show_cursor
                exec "$SCRIPT_DIR/bin/purge.sh"
                ;;
            "CHAR:3")
                show_cursor
                exec "$SCRIPT_DIR/bin/analyze.sh"
                ;;
            "CHAR:4")
                show_cursor
                exec "$SCRIPT_DIR/bin/status.sh"
                ;;
            "CHAR:5")
                show_cursor
                exec "$SCRIPT_DIR/bin/optimize.sh"
                ;;
            "CHAR:6")
                show_cursor
                exec "$SCRIPT_DIR/bin/completion.sh"
                ;;
            "MORE")
                show_cursor
                clear
                show_help
                exit 0
                ;;
            "VERSION")
                show_cursor
                clear
                show_version
                exit 0
                ;;
            "UPDATE")
                [[ "${MAIN_MENU_SHOW_UPDATE:-false}" == "true" ]] || continue
                show_cursor
                clear
                update_anteater
                exit 0
                ;;
            "QUIT") cleanup_and_exit ;;
        esac

        drain_pending_input
    done
}

# CLI dispatch
main() {
    local -a args=()
    for arg in "$@"; do
        case "$arg" in
            --debug)
                export AA_DEBUG=1
                ;;
            *)
                args+=("$arg")
                ;;
        esac
    done

    case "${args[0]:-""}" in
        "clean")
            exec "$SCRIPT_DIR/bin/clean.sh" "${args[@]:1}"
            ;;
        "purge")
            exec "$SCRIPT_DIR/bin/purge.sh" "${args[@]:1}"
            ;;
        "analyze")
            exec "$SCRIPT_DIR/bin/analyze.sh" "${args[@]:1}"
            ;;
        "status")
            exec "$SCRIPT_DIR/bin/status.sh" "${args[@]:1}"
            ;;
        "optimize")
            exec "$SCRIPT_DIR/bin/optimize.sh" "${args[@]:1}"
            ;;
        "completion")
            exec "$SCRIPT_DIR/bin/completion.sh" "${args[@]:1}"
            ;;
        "update")
            local force_update=false
            local nightly_update=false
            for arg in "${args[@]:1}"; do
                case "$arg" in
                    --force | -f) force_update=true ;;
                    --nightly) nightly_update=true ;;
                    *)
                        echo "Unknown update option: $arg"
                        echo "Use 'anteater update [--force] [--nightly]' for supported options."
                        exit 1
                        ;;
                esac
            done
            update_anteater "$force_update" "$nightly_update"
            exit 0
            ;;
        "remove")
            local dry_run_remove=false
            for arg in "${args[@]:1}"; do
                case "$arg" in
                    "--dry-run" | "-n") dry_run_remove=true ;;
                    *)
                        echo "Unknown remove option: $arg"
                        echo "Use 'anteater remove [--dry-run]' for supported options."
                        exit 1
                        ;;
                esac
            done
            remove_anteater "$dry_run_remove"
            ;;
        "help" | "--help" | "-h")
            show_help
            exit 0
            ;;
        "version" | "--version" | "-V")
            show_version
            exit 0
            ;;
        "")
            check_for_updates
            interactive_main_menu
            ;;
        *)
            echo "Unknown command: ${args[0]}"
            echo "Use 'anteater --help' for usage information."
            exit 1
            ;;
    esac
}

if [[ "${ANTEATER_TEST_MODE:-0}" == "1" && "${ANTEATER_SKIP_MAIN:-0}" == "1" ]]; then
    :
else
    main "$@"
fi
